# dependencies
/node_modules
/.pnp
.pnp.*

# next.js
/.next/
/out/
next-env.d.ts

# production
/build

# env — never commit real keys (invariant #7)
.env
.env.local
.env*.local

# runtime telemetry log (append-only, can grow) — not source
/var

# eval runs ARE committed: the accuracy audit trail + regression baseline (SPEC M3).

# extraction working artifacts (page renders during `npm run extract`)
/kb/.work

# misc
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.vscode/*
!.vscode/extensions.json
.idea

# local dev-server launcher (machine-specific path)
.claude/launch.json

# TypeScript incremental build info
*.tsbuildinfo

# Claude Code machine-local settings (skills ARE committed)
.claude/settings.local.json
